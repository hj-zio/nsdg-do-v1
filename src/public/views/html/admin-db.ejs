<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/resources/do_circle.svg">
    <title>DO :: 관리자</title>

    <meta name="title" content="DO">
    <meta name="description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:title" content="DO">
    <meta property="og:description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:image" content="/resources/og_image.png">
    <meta property="og:url" content="v5.dghs.site">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.1/css/dataTables.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.1/js/dataTables.min.js"></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KCZ7CDL7SL"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag() { dataLayer.push(arguments); } gtag('js', new Date()); gtag('config', 'G-KCZ7CDL7SL'); 
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/admin-db.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body class="h-screen">
    <div class="flex h-full">
        <!-- 사이드바 -->
        <div class="w-1/6 h-full p-4 bg-gray-0">
            <div class="px-2 py-4">
                <img src="/resources/do_logo.png" width="25" height="25" onclick="location.href='/admin'">
            </div>
            <ul class="mt-3">
                <li>
                    <a class="flex items-center p-2 rounded text-[16px] text-gray-600 pretendard-600">
                        검색
                    </a>
                    <a href="/admin"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">👥</span>
                        유저 검색
                    </a>
                    <a href="/admin/db"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🔍</span>
                        DB 검색
                    </a>

                    <a class="flex items-center p-2 mt-2 rounded text-[16px] text-gray-600 pretendard-600">
                        관리
                    </a>
                    <a href="/admin/server"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🖥️</span>
                        서버 관리
                    </a>
                    <a href="/admin/ins"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🛡️</span>
                        점검 관리
                    </a>
                    <a href="/admin/meal"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🥄</span>
                        급식 관리
                    </a>
                    <a href="/admin/charge"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">💳</span>
                        충전 관리
                    </a>
                    <a href="/admin/mealRating"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">📊</span>
                        급식 평가
                    </a>
                    <a href="/admin/lostItem"
                        class="flex items-center p-2 py-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🪧</span>
                        분실물 관리
                    </a>
                </li>
            </ul>
        </div>

        <!-- 메인 -->
        <div class="w-5/6 h-full px-5 bg-gray-100">
            <div class="flex flex-col h-full">
                <div class="flex items-center justify-between px-5 py-6 text-[24px] text-gray-800 pretendard-700">
                    <span>데이터베이스 검색</span>
                    <button
                        class="px-3 py-2 rounded bg-blue-100 text-[16px] text-blue-600 pretendard-600 hover:scale-95 active:scale-90 transition-all duration-100 ease-in-out"
                        onclick="searchDB()">
                        조회하기
                    </button>
                </div>
                <!-- 컨테이너 -->
                <div class="flex flex-col max-h-screen px-5 py-3 mb-3 bg-white rounded-md overflow-hidden">
                    <div id="condition" class="flex-shrink-0 mt-3">
                        <div class="flex border-t border-gray-300">
                            <div class="flex-1 px-4 py-3 bg-gray-100 text-gray-700">DB *</div>
                            <div class="flex-1 px-4 py-3 bg-white text-gray-700">
                                <select id="db-select"
                                    class="w-full p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none">
                                    <option value="DB" default>DB</option>
                                </select>
                            </div>
                            <div class="flex-1 px-4 py-3 bg-gray-100 text-gray-700">테이블 *</div>
                            <div class="flex-1 px-4 py-3 bg-white text-gray-700" onclick="getTableList()">
                                <select id="db-table"
                                    class="w-full p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none"></select>
                            </div>
                        </div>
                        <div class="flex border-t border-gray-300">
                            <div class="flex-1 px-4 py-3 bg-gray-100 text-gray-700">조건 1</div>
                            <div class="flex-1 px-4 py-3 bg-white text-gray-700">
                                <div class="flex items-center space-x-2">
                                    <select id="where1-column"
                                        class="w-[45%] p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none"
                                        onclick="getColumnList()"></select>
                                    <select id="where1-operand"
                                        class="w-[15%] p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none text-center">
                                        <option value=">">&gt;</option>
                                        <option value="<">&lt;</option>
                                        <option value=">=">&gt;=</option>
                                        <option value="<=">&lt;=</option>
                                        <option value="=">=</option>
                                        <option value="!=">!=</option>
                                    </select>
                                    <input id="where1-value"
                                        class="w-[45%] p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none" />
                                </div>
                            </div>
                            <div class="flex-1 px-4 py-3 bg-gray-100 text-gray-700">조건 2</div>
                            <div class="flex-1 px-4 py-3 bg-white text-gray-700">
                                <div class="flex items-center space-x-2">
                                    <select id="where2-column"
                                        class="w-[45%] p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none"></select>
                                    <select id="where2-operand"
                                        class="w-[15%] p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none text-center">
                                        <option value=">">&gt;</option>
                                        <option value="<">&lt;</option>
                                        <option value=">=">&gt;=</option>
                                        <option value="<=">&lt;=</option>
                                        <option value="=">=</option>
                                        <option value="!=">!=</option>
                                    </select>
                                    <input id="where2-value"
                                        class="w-[45%] p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none" />
                                </div>
                            </div>
                        </div>
                        <div class="flex border-y border-gray-300">
                            <div class="flex-1 px-4 py-3 bg-gray-100 text-gray-700">Custom Query</div>
                            <div class="flex-1 px-4 py-3 bg-white text-gray-700">
                                <input id="query-input"
                                    class="w-full p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none"
                                    placeholder="Query를 입력하세요." />
                            </div>
                            <div class="flex-1 px-4 py-3 bg-gray-100 text-gray-700">결과 레코드 제한 *</div>
                            <div class="flex-1 px-4 py-3 bg-white text-gray-700">
                                <input id="limit-input"
                                    class="w-full p-2 border border-gray-300 bg-white rounded-md appearance-none outline-none"
                                    placeholder="제한할 레코드 수를 입력하세요." value="100" />
                            </div>
                        </div>
                    </div>
                    <div id="result" class="flex-1 min-h-0 mt-3 overflow-auto"></div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
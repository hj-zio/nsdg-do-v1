<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/resources/do_circle.svg">
    <title>DO :: 관리자</title>

    <meta name="title" content="DO">
    <meta name="description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:title" content="DO">
    <meta property="og:description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:image" content="/resources/og_image.png">
    <meta property="og:url" content="v5.dghs.site">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.1/css/dataTables.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.1/js/dataTables.min.js"></script>

     <!-- Google tag (gtag.js)  -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KCZ7CDL7SL"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag() { dataLayer.push(arguments); } gtag('js', new Date()); gtag('config', 'G-KCZ7CDL7SL'); 
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/admin-lostItem.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body class="h-screen">
    <div class="flex h-full">
        <div class="w-1/6 h-full p-4 bg-gray-0">
            <div class="px-2 py-4">
                <img src="/resources/do_logo.png" width="25" height="25" onclick="location.href='/admin'">
            </div>
            <ul class="mt-3">
                <li>
                    <a class="flex items-center p-2 rounded text-[16px] text-gray-600 pretendard-600">
                        검색
                    </a>
                    <a href="/admin"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">👥</span>
                        유저 검색
                    </a>
                    <a href="/admin/db"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🔍</span>
                        DB 검색
                    </a>

                    <a class="flex items-center p-2 mt-2 rounded text-[16px] text-gray-600 pretendard-600">
                        관리
                    </a>
                    <a href="/admin/server"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🖥️</span>
                        서버 관리
                    </a>
                    <a href="/admin/ins"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🛡️</span>
                        점검 관리
                    </a>
                    <a href="/admin/meal"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🥄</span>
                        급식 관리
                    </a>
                    <a href="/admin/charge"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">💳</span>
                        충전 관리
                    </a>
                    <a href="/admin/mealRating"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">📊</span>
                        급식 평가
                    </a>
                    <a href="/admin/lostItem"
                        class="flex items-center p-2 py-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🪧</span>
                        분실물 관리
                    </a>
                </li>
            </ul>
        </div>

        <div class="w-5/6 h-full px-5 bg-gray-100 overflow-y-auto">
            <div class="flex flex-col h-full">
                <div class="flex items-center justify-between px-5 py-6 text-[24px] text-gray-800 pretendard-700">
                    분실물 관리
                </div>

                <div class="grid grid-cols-4 gap-4 px-5 mb-6">
                    <div class="bg-white p-4 rounded-lg border border-gray-200">
                        <div class="text-[14px] text-gray-600 pretendard-500">전체 게시글</div>
                        <div id="totalCount" class="text-[28px] text-gray-800 pretendard-700 mt-2">0</div>
                    </div>
                    <div class="bg-white p-4 rounded-lg border border-gray-200">
                        <div class="text-[14px] text-gray-600 pretendard-500">활성 게시글</div>
                        <div id="activeCount" class="text-[28px] text-blue-600 pretendard-700 mt-2">0</div>
                    </div>
                    <div class="bg-white p-4 rounded-lg border border-gray-200">
                        <div class="text-[14px] text-gray-600 pretendard-500">숨김 게시글</div>
                        <div id="hiddenCount" class="text-[28px] text-orange-600 pretendard-700 mt-2">0</div>
                    </div>
                    <div class="bg-white p-4 rounded-lg border border-gray-200">
                        <div class="text-[14px] text-gray-600 pretendard-500">삭제 게시글</div>
                        <div id="deletedCount" class="text-[28px] text-red-600 pretendard-700 mt-2">0</div>
                    </div>
                </div>

                <div class="px-5 pb-6">
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <table id="lostItemTable" class="display" style="width:100%">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>제목</th>
                                    <th>작성자</th>
                                    <th>학번</th>
                                    <th>작성일</th>
                                    <th>게시글 상태</th>
                                    <th>관리 상태</th>
                                    <th>관리</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="detailModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-lg max-w-[800px] w-full max-h-[90vh] overflow-y-auto">
            <div class="sticky top-0 bg-white border-b border-gray-200 p-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-[20px] pretendard-700 text-gray-800">게시글 상세</h2>
                    <button onclick="closeDetailModal()" class="text-gray-400 hover:text-gray-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            <div id="detailContent" class="p-6">
            </div>
        </div>
    </div>

    <div id="historyModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-lg max-w-[800px] w-full max-h-[90vh] overflow-y-auto">
            <div class="sticky top-0 bg-white border-b border-gray-200 p-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-[20px] pretendard-700 text-gray-800">수정 이력</h2>
                    <button onclick="closeHistoryModal()" class="text-gray-400 hover:text-gray-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
            <div id="historyContent" class="p-6">
            </div>
        </div>
    </div>
</body>

</html>
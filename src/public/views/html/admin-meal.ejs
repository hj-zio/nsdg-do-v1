<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/resources/do_circle.svg">
    <title>DO :: 관리자</title>

    <meta name="title" content="DO">
    <meta name="description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:title" content="DO">
    <meta property="og:description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:image" content="/resources/og_image.png">
    <meta property="og:url" content="v5.dghs.site">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.1/css/dataTables.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.1/js/dataTables.min.js"></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KCZ7CDL7SL"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag() { dataLayer.push(arguments); } gtag('js', new Date()); gtag('config', 'G-KCZ7CDL7SL'); 
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/admin-meal.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body class="h-screen">
    <div class="flex h-full">
        <!-- 사이드바 -->
        <div class="w-1/6 h-full p-4 bg-gray-0">
            <div class="px-2 py-4">
                <img src="/resources/do_logo.png" width="25" height="25" onclick="location.href='/admin'">
            </div>
            <ul class="mt-3">
                <li>
                    <a class="flex items-center p-2 rounded text-[16px] text-gray-600 pretendard-600">
                        검색
                    </a>
                    <a href="/admin"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">👥</span>
                        유저 검색
                    </a>
                    <a href="/admin/db"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🔍</span>
                        DB 검색
                    </a>

                    <a class="flex items-center p-2 mt-2 rounded text-[16px] text-gray-600 pretendard-600">
                        관리
                    </a>
                    <a href="/admin/server"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🖥️</span>
                        서버 관리
                    </a>
                    <a href="/admin/ins"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🛡️</span>
                        점검 관리
                    </a>
                    <a href="/admin/meal"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🥄</span>
                        급식 관리
                    </a>
                    <a href="/admin/charge"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">💳</span>
                        충전 관리
                    </a>
                    <a href="/admin/mealRating"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">📊</span>
                        급식 평가
                    </a>
                    <a href="/admin/lostItem"
                        class="flex items-center p-2 py-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🪧</span>
                        분실물 관리
                    </a>
                </li>
            </ul>
        </div>

        <!-- 메인 -->
        <div class="bg-gray-100 h-full px-5 w-5/6">
            <div class="flex flex-col h-full">
                <div class="flex items-center justify-between pretendard-700 px-5 py-6 text-[24px] text-gray-800">
                    <span>급식 관리</span>
                    <button
                        class="active:scale-90 bg-blue-100 duration-100 ease-in-out hover:scale-95 pretendard-600 px-3 py-2 rounded text-[16px] text-blue-600 transition-all"
                        onclick="uploadMealFile()">
                        등록하기
                    </button>
                </div>
                <!-- 컨테이너 -->
                <div class="bg-white flex flex-col max-h-screen mb-3 overflow-hidden px-5 py-3 rounded-md">
                    <div id="condition" class="flex-shrink-0 mt-3">
                        <div class="border-gray-300 border-t flex">
                            <div class="basis-1/4 bg-gray-100 px-4 py-3 text-gray-700">시작일 *</div>
                            <div class="bg-white flex-1 px-4 py-3 text-gray-700">
                                <div class="relative">
                                    <input id="meal-start" type="date"
                                        class="appearance-none bg-white border border-gray-300 outline-none p-2 rounded-md w-full" />
                                </div>
                            </div>
                            <div class="bg-gray-100 flex-1 px-4 py-3 text-gray-700">종료일 *</div>
                            <div class="bg-white flex-1 px-4 py-3 text-gray-700">
                                <div class="relative">
                                    <input id="meal-end" type="date"
                                        class="appearance-none bg-white border border-gray-300 outline-none p-2 rounded-md w-full" />
                                </div>
                            </div>
                        </div>
                        <div class="border-gray-300 border-y flex">
                            <div class="basis-1/4 bg-gray-100 px-4 py-3 text-gray-700">파일 *</div>
                            <div class="basis-3/4 bg-gray-0 px-4 py-3 text-gray-700">
                                <label for="meal-file"
                                    class="border border-gray-300 cursor-pointer flex items-center justify-between outline-none p-2 rounded-md w-full">
                                    <span id="meal-file-text" class="text-gray-400">파일을 선택해주세요.</span>
                                    <input id="meal-file" type="file" class="hidden"
                                        onchange="handleFileChange(event)" />
                                </label>
                            </div>
                        </div>
                    </div>
                    <div id="result" class="flex-1 min-h-0 mt-3 overflow-auto"></div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
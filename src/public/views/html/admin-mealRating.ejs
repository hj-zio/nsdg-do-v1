<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/resources/do_circle.svg">
    <title>DO :: 관리자</title>

    <meta name="title" content="DO">
    <meta name="description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:title" content="DO">
    <meta property="og:description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:image" content="/resources/og_image.png">
    <meta property="og:url" content="v5.dghs.site">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.1/css/dataTables.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.1/js/dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KCZ7CDL7SL"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag() { dataLayer.push(arguments); } gtag('js', new Date()); gtag('config', 'G-KCZ7CDL7SL'); 
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/admin-mealRating.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body class="h-screen">
    <div class="flex h-full">
        <div class="w-1/6 h-full p-4 bg-gray-0">
            <div class="px-2 py-4">
                <img src="/resources/do_logo.png" width="25" height="25" onclick="location.href='/admin'">
            </div>
            <ul class="mt-3">
                <li>
                    <a class="flex items-center p-2 rounded text-[14px] sm:text-[16px] text-gray-600 pretendard-600">
                        검색
                    </a>
                    <a href="/admin"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[16px] sm:text-[18px] me-2 tossface">👥</span>
                        유저 검색
                    </a>
                    <a href="/admin/db"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[16px] sm:text-[18px] me-2 tossface">🔍</span>
                        DB 검색
                    </a>

                    <a class="flex items-center p-2 mt-2 rounded text-[14px] sm:text-[16px] text-gray-600 pretendard-600">
                        관리
                    </a>
                    <a href="/admin/server"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[16px] sm:text-[18px] me-2 tossface">🖥️</span>
                        서버 관리
                    </a>
                    <a href="/admin/ins"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[16px] sm:text-[18px] me-2 tossface">🛡️</span>
                        점검 관리
                    </a>
                    <a href="/admin/meal"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[16px] sm:text-[18px] me-2 tossface">🥄</span>
                        급식 관리
                    </a>
                    <a href="/admin/charge"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[16px] sm:text-[18px] me-2 tossface">💳</span>
                        충전 관리
                    </a>
                    <a href="/admin/mealRating"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">📊</span>
                        급식 평가
                    </a>
                    <a href="/admin/lostItem"
                        class="flex items-center p-2 py-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🪧</span>
                        분실물 관리
                    </a>
                </li>
            </ul>
        </div>

        <div class="w-5/6 h-full px-5 bg-gray-100 overflow-y-auto">
            <div class="py-6">
                <div class="bg-white rounded-lg shadow-sm p-6">
                    <div class="mb-6">
                        <h1 class="text-[20px] sm:text-[24px] font-bold text-gray-800 pretendard-700">급식 평가 관리</h1>
                        <p class="text-[14px] sm:text-[16px] text-gray-600 mt-2 pretendard-400">날짜별 급식 평가 현황을 확인할 수 있습니다.</p>
                    </div>
                    
                    <div class="mb-6 flex items-center gap-4">
                        <input type="date" id="selectedDate" 
                               class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        <button onclick="loadMealRatingData()" 
                                class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-[14px] sm:text-[16px] pretendard-600">
                            조회
                        </button>
                    </div>
                    
                    <div id="loadingMessage" class="text-center py-12 text-[14px] sm:text-[16px] text-gray-500 pretendard-400" style="display: none;">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600 mx-auto mb-4"></div>
                        데이터를 불러오는 중...
                    </div>
                    
                    <div id="noDataMessage" class="text-center py-12 text-[14px] sm:text-[16px] text-gray-500 pretendard-400" style="display: none;">
                        <div class="text-4xl mb-4 tossface">📊</div>
                        선택한 날짜에 평가 데이터가 없습니다.
                    </div>
                    
                    <div id="chartsContainer" class="grid grid-cols-1 lg:grid-cols-3 gap-6" style="display: none;">
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h3 class="text-[16px] sm:text-[18px] font-semibold text-gray-800 mb-4 text-center pretendard-600">조식 평가</h3>
                            <div class="relative h-64 mb-4">
                                <canvas id="breakfastChart"></canvas>
                                <div id="breakfastNoData" class="absolute inset-0 flex flex-col items-center justify-center text-gray-400" style="display: none;">
                                    <div class="text-3xl mb-2 tossface">📊</div>
                                    <div class="text-[12px] sm:text-[14px] pretendard-400">수집된 데이터가 없습니다</div>
                                </div>
                            </div>
                            <div id="breakfastSummary" class="text-[12px] sm:text-[14px] text-gray-600 text-center pretendard-400"></div>
                        </div>
                        
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h3 class="text-[16px] sm:text-[18px] font-semibold text-gray-800 mb-4 text-center pretendard-600">중식 평가</h3>
                            <div class="relative h-64 mb-4">
                                <canvas id="lunchChart"></canvas>
                                <div id="lunchNoData" class="absolute inset-0 flex flex-col items-center justify-center text-gray-400" style="display: none;">
                                    <div class="text-3xl mb-2 tossface">📊</div>
                                    <div class="text-[12px] sm:text-[14px] pretendard-400">수집된 데이터가 없습니다</div>
                                </div>
                            </div>
                            <div id="lunchSummary" class="text-[12px] sm:text-[14px] text-gray-600 text-center pretendard-400"></div>
                        </div>
                        
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h3 class="text-[16px] sm:text-[18px] font-semibold text-gray-800 mb-4 text-center pretendard-600">석식 평가</h3>
                            <div class="relative h-64 mb-4">
                                <canvas id="dinnerChart"></canvas>
                                <div id="dinnerNoData" class="absolute inset-0 flex flex-col items-center justify-center text-gray-400" style="display: none;">
                                    <div class="text-3xl mb-2 tossface">📊</div>
                                    <div class="text-[12px] sm:text-[14px] pretendard-400">수집된 데이터가 없습니다</div>
                                </div>
                            </div>
                            <div id="dinnerSummary" class="text-[12px] sm:text-[14px] text-gray-600 text-center pretendard-400"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>

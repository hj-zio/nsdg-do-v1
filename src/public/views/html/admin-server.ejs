<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/resources/do_circle.svg">
    <title>DO :: 관리자</title>

    <meta name="title" content="DO">
    <meta name="description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:title" content="DO">
    <meta property="og:description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:image" content="/resources/og_image.png">
    <meta property="og:url" content="v5.dghs.site">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.1/css/dataTables.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.1/js/dataTables.min.js"></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KCZ7CDL7SL"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag() { dataLayer.push(arguments); } gtag('js', new Date()); gtag('config', 'G-KCZ7CDL7SL'); 
    </script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/admin-server.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body class="h-screen">
    <div class="flex h-full">
        <!-- 사이드바 -->
        <div class="w-1/6 h-full p-4 bg-gray-0">
            <div class="px-2 py-4">
                <img src="/resources/do_logo.png" width="25" height="25" onclick="location.href='/admin'">
            </div>
            <ul class="mt-3">
                <li>
                    <a class="flex items-center p-2 rounded text-[16px] text-gray-600 pretendard-600">
                        검색
                    </a>
                    <a href="/admin"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">👥</span>
                        유저 검색
                    </a>
                    <a href="/admin/db"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🔍</span>
                        DB 검색
                    </a>

                    <a class="flex items-center p-2 mt-2 rounded text-[16px] text-gray-600 pretendard-600">
                        관리
                    </a>
                    <a href="/admin/server"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🖥️</span>
                        서버 관리
                    </a>
                    <a href="/admin/ins"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🛡️</span>
                        점검 관리
                    </a>
                    <a href="/admin/meal"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🥄</span>
                        급식 관리
                    </a>
                    <a href="/admin/charge"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">💳</span>
                        충전 관리
                    </a>
                    <a href="/admin/mealRating"
                        class="flex items-center p-2 py-2 my-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">📊</span>
                        급식 평가
                    </a>
                    <a href="/admin/lostItem"
                        class="flex items-center p-2 py-2 rounded text-[18px] text-gray-700 pretendard-600 hover:bg-blue-100 hover:text-blue-600">
                        <span class="text-[18px] me-2 tossface">🪧</span>
                        분실물 관리
                    </a>
                </li>
            </ul>
        </div>

        <!-- 메인 -->
        <div class="w-5/6 h-full px-5 bg-gray-100">
            <div class="flex flex-col h-full">
                <div class="flex items-center justify-between px-5 py-6 text-[24px] text-gray-800 pretendard-700">
                    <span>서버 모니터링</span>
                    <select id="time-selection"
                        class="px-3 py-2 text-[16px] text-gray-600 pretendard-600 bg-gray-0 rounded transition-all duration-100 ease-in-out hover:scale-95 active:scale-90"
                        onclick="setData()">
                        <option value="604800000">지난 일주일</option>
                        <option value="86400000">지난 1일</option>
                        <option value="43200000">지난 12시간</option>
                        <option value="21600000">지난 6시간</option>
                        <option value="10800000">지난 3시간</option>
                        <option value="3600000">지난 1시간</option>
                        <option value="1800000" selected>지난 30분</option>
                        <option value="900000">지난 15분</option>
                        <option value="300000">지난 5분</option>
                    </select>
                </div>
                <!-- 컨테이너 -->
                <div class="flex flex-col overflow-scroll max-h-screen px-5 py-5 mb-3 space-y-4 bg-white rounded-md">
                    <div class="flex flex-row box-border space-x-4">
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <div class="flex flex-col justify-between h-full">
                                <span class="text-[18px] text-gray-700 pretendard-600">전체</span>
                                <span id="totalRequest" class="self-end text-[26px] text-gray-700 pretendard-700">
                                    <div class="w-12 h-10 rounded bg-gray-300 animate-pulse"></div>
                                </span>
                            </div>
                        </div>
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <div class="flex flex-col justify-between h-full">
                                <span class="text-[18px] text-gray-700 pretendard-600">성공</span>
                                <span id="successRequest" class="self-end text-[26px] text-blue-500 pretendard-700">
                                    <div class="w-12 h-10 rounded bg-gray-300 animate-pulse"></div>
                                </span>
                            </div>
                        </div>
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <div class="flex flex-col justify-between h-full">
                                <span class="text-[18px] text-gray-700 pretendard-600">실패</span>
                                <span id="failRequest" class="self-end text-[26px] text-red-500 pretendard-700">
                                    <div class="w-12 h-10 rounded bg-gray-300 animate-pulse"></div>
                                </span>
                            </div>
                        </div>
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <div class="flex flex-col justify-between h-full">
                                <span class="text-[18px] text-gray-700 pretendard-600">평균응답시간</span>
                                <span id="avgExecution" class="self-end text-[26px] text-gray-700 pretendard-700">
                                    <div class="w-12 h-10 rounded bg-gray-300 animate-pulse"></div>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="flex flex-row box-border space-x-4">
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <span class="text-[18px] text-gray-700 pretendard-600">서비스별 상태</span>
                            <div class="flex flex-col">
                                <div class="flex mt-2 border-t border-gray-300">
                                    <div
                                        class="basis-2/4 px-4 py-2 text-[14px] text-center text-gray-700 pretendard-600 bg-gray-100">
                                        경로</div>
                                    <div
                                        class="basis-1/4 px-4 py-2 text-[14px] text-center text-gray-700 pretendard-600 bg-gray-100">
                                        상태</div>
                                    <div
                                        class="basis-1/4 px-4 py-2 text-[14px] text-center text-gray-700 pretendard-600 bg-gray-100">
                                        응답시간</div>
                                </div>
                                <div id="serviceStatus" class="h-fit max-h-[150px] overflow-scroll">
                                    <div class="w-[100%] h-8 mt-1 rounded bg-gray-300 animate-pulse"></div>
                                    <div class="w-[100%] h-8 mt-1 rounded bg-gray-300 animate-pulse"></div>
                                    <div class="w-[100%] h-8 mt-1 rounded bg-gray-300 animate-pulse"></div>
                                </div>
                            </div>
                        </div>
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <span class="text-[18px] text-gray-700 pretendard-600">상위 네트워크 응답</span>
                            <div class="flex flex-col">
                                <div class="flex mt-2 border-t border-gray-300">
                                    <div
                                        class="basis-2/4 px-4 py-2 text-[14px] text-center text-gray-700 pretendard-600 bg-gray-100">
                                        경로</div>
                                    <div
                                        class="basis-1/4 px-4 py-2 text-[14px] text-center text-gray-700 pretendard-600 bg-gray-100">
                                        상태</div>
                                    <div
                                        class="basis-1/4 px-4 py-2 text-[14px] text-center text-gray-700 pretendard-600 bg-gray-100">
                                        응답시간</div>
                                </div>
                                <div id="topServiceStatus" class="h-fit max-h-[150px] overflow-scroll">
                                    <div class="w-[100%] h-8 mt-1 rounded bg-gray-300 animate-pulse"></div>
                                    <div class="w-[100%] h-8 mt-1 rounded bg-gray-300 animate-pulse"></div>
                                    <div class="w-[100%] h-8 mt-1 rounded bg-gray-300 animate-pulse"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="flex flex-row box-border space-x-4">
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <span class="text-[18px] text-gray-700 pretendard-600">CPU</span>
                            <canvas id="cpuChart" class="w-full"></canvas>
                        </div>
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <span class="text-[18px] text-gray-700 pretendard-600">메모리</span>
                            <canvas id="memoryChart" class="w-full"></canvas>
                        </div>
                    </div>
                    <div class="flex flex-row box-border space-x-4">
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <span class="text-[18px] text-gray-700 pretendard-600">디스크</span>
                            <canvas id="diskChart" class="w-full"></canvas>
                        </div>
                        <div class="flex-1 border border-gray-300 p-5 rounded-md">
                            <span class="text-[18px] text-gray-700 pretendard-600">네트워크</span>
                            <canvas id="networkChart" class="w-full"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
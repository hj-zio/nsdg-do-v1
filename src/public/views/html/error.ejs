<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/resources/do_circle.svg">
    <title>DO :: 오류</title>

    <meta name="title" content="DO">
    <meta name="description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:title" content="DO">
    <meta property="og:description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:image" content="/resources/og_image.png">
    <meta property="og:url" content="v5.dghs.site">

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KCZ7CDL7SL"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag() { dataLayer.push(arguments); } gtag('js', new Date()); gtag('config', 'G-KCZ7CDL7SL'); 
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }
        
        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body>
    <div id='wrapper' class="m-0 p-0 box-border">
        <div class="
            relative flex flex-col items-center justify-start
            overflow-x-hidden overflow-y-hidden
            p-0 gap-0 text-[20px] bg-gray-100 w-full full-height">

            <div id="TOP_AREA" class="
                relative flex justify-start items-end
                flex-row flex-nowrap 
                flex-grow-0 flex-shrink-0 basis-auto
                h-[80px] max-w-[600px] 
                overflow-x-hidden overflow-y-hidden
                p-0 px-[20px] gap-[10px]
                text-[20px] bg-gray-100
                w-full sm:w-[100%] md:w-[70%] lg:w-[50%]">
                <img src="/resources/do_logo.png" width="32" height="32" onclick="location.href='/'">
            </div>

            <div id="CONTENT_AREA" class="
                relative flex flex-col justify-center items-center
                flex-nowrap 
                flex-grow flex-shrink-0 basis-0
                h-[1fr] max-w-[600px]
                overflow-x-auto overflow-y-auto
                p-[10px] px-[20px] gap-[5px]
                text-[20px] bg-gray-100
                w-full sm:w-[100%] md:w-[70%] lg:w-[50%]">
                <img src="/resources/warning.png" width="120" height="120">
                <p class="text-[20px] sm:text-[24px] gray-100 pretendard-600 text-center">
                    <%- title %>
                </p>
                <p class="text-[16px] sm:text-[20px] gray-70 pretendard-500 text-center">
                    <%- subtitle %>
                </p>
            </div>

            <div id="BOTTOM_AREA" class="
                relative flex flex-col justify-end items-start
                flex-nowrap 
                flex-grow-0 flex-shrink-0 basis-auto
                h-[100px] max-w-[600px]
                overflow-x-hidden overflow-y-hidden
                p-0 pb-[50px] px-[20px] gap-[10px]
                text-[20px] bg-gray-100
                w-full sm:w-[100%] md:w-[70%] lg:w-[50%]">

                <button class="
                    w-[100%] h-[48px] text-[18px] rounded-[18px] bg-primary-50 
                    text-[var(--gray-0)] text-center pretendard-500
                    sm:h-[54px] sm:text-[20px]
                    active:scale-95 hover:bg-[var(--primary-60)] transition-all duration-100 ease-in-out"
                    onclick="location.href='/'">
                    처음으로 돌아가기
                </button>
            </div>
        </div>
    </div>
</body>

</html>
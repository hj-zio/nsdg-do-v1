    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/lostItem.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body>
    <div class="relative flex flex-col flex-nowrap items-center justify-start w-full h-screen overflow-x-hidden overflow-y-hidden bg-gray-50">
        
        <!-- TOP_AREA -->
        <div id="TOP_AREA" class="relative flex flex-col flex-nowrap flex-grow-0 flex-shrink-0 basis-auto items-start justify-start w-full max-w-[600px] sm:w-[100%] md:w-[70%] lg:w-[50%] overflow-x-hidden overflow-y-hidden px-[20px] space-y-5">
            <div class="flex flex-row items-center justify-between w-full h-[60px] pt-[10px]">
                <button onclick="location.href='/lostItem'" class="flex items-center gap-2 text-gray-600 hover:text-gray-800">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
                <h1 class="text-[20px] pretendard-700 text-gray-800">분실물 작성</h1>
                <div class="w-5"></div>
            </div>
        </div>

        <!-- CONTENT_AREA -->
        <div id="CONTENT_AREA" class="relative flex flex-col flex-nowrap flex-grow flex-shrink basis-0 items-start justify-start w-full max-w-[600px] sm:w-[100%] md:w-[70%] lg:w-[50%] overflow-x-hidden overflow-y-auto px-[20px] space-y-5 pb-[20px]">
            
            <!-- 작성 폼 -->
            <div class="w-full bg-white rounded-lg border border-gray-200 p-6">
                <div class="flex flex-col gap-6">
                    <!-- 제목 -->
                    <div>
                        <label for="title" class="block text-[14px] pretendard-600 text-gray-700 mb-2">
                            제목 <span class="text-red-500">*</span>
                        </label>
                        <input 
                            type="text" 
                            id="title" 
                            placeholder="분실물 제목을 입력하세요"
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 pretendard-400"
                        />
                    </div>

                    <!-- 내용 -->
                    <div>
                        <label for="content" class="block text-[14px] pretendard-600 text-gray-700 mb-2">
                            내용 <span class="text-red-500">*</span>
                        </label>
                        <textarea 
                            id="content" 
                            rows="10"
                            placeholder="분실물에 대한 자세한 설명을 입력하세요"
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 pretendard-400 resize-none"
                        ></textarea>
                    </div>

                    <!-- 버튼 -->
                    <button 
                        id="submitPostBtn"
                        class="w-full py-3 bg-blue-600 text-white rounded-lg pretendard-600 hover:bg-blue-700 transition-colors"
                    >
                        등록
                    </button>
                </div>
            </div>

        </div>

        <!-- BOTTOM_AREA -->
        <div id="BOTTOM_AREA"
            class="relative flex flex-col flex-nowrap flex-grow-0 flex-shrink-0 basis-auto items-start justify-end w-full h-[80px] max-w-[600px] sm:w-[100%] md:w-[70%] lg:w-[50%] overflow-x-hidden overflow-y-hidden px-[1px] space-y-5 bg-gray-50">
            <div class="flex flex-row items-center justify-between w-full h-[79px] rounded-tl-[25px] rounded-tr-[25px] bg-gray-0"
                style="outline: 1px solid var(--gray-20);">
                <div class="flex-1 text-center rounded-[30px] pt-2 pb-2 ms-3 me-3 group active:scale-95 hover:bg-gray-100 transition-all duration-100 ease-in-out"
                    onclick="location.href='/'">
                    <svg xmlns="http://www.w3.org/2000/svg"
                        class="h-[23px] w-[23px] mx-auto text-gray-500 group-hover:text-blue-600" viewBox="0 0 24 24"
                        fill="currentColor">
                        <path

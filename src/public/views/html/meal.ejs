                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- 급식 평가 모달 -->
        <div id="ratingModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
            <div class="bg-white rounded-lg p-6 m-4 max-w-sm w-full">
                <div class="text-center mb-4">
                    <h3 class="text-[16px] sm:text-[18px] text-gray-800 pretendard-700">급식 평가</h3>
                    <p id="modalMealInfo" class="text-[14px] sm:text-[16px] text-gray-600 pretendard-500"></p>
                </div>

                <div class="space-y-3 mb-6">
                    <button
                        class="rating-btn w-full p-3 text-left rounded-lg border-2 border-gray-200 hover:border-green-400 hover:bg-green-50 transition-all duration-200"
                        data-rating="5">
                        <div class="flex items-center">
                            <span class="tossface text-[20px] sm:text-[24px] mr-3">😍</span>
                            <span class="text-[16px] sm:text-[18px] text-gray-700 pretendard-600">매우 맛있었다</span>
                        </div>
                    </button>

                    <button
                        class="rating-btn w-full p-3 text-left rounded-lg border-2 border-gray-200 hover:border-blue-400 hover:bg-blue-50 transition-all duration-200"
                        data-rating="4">
                        <div class="flex items-center">
                            <span class="tossface text-[20px] sm:text-[24px] mr-3">😊</span>
                            <span class="text-[16px] sm:text-[18px] text-gray-700 pretendard-600">맛있었다</span>
                        </div>
                    </button>

                    <button
                        class="rating-btn w-full p-3 text-left rounded-lg border-2 border-gray-200 hover:border-yellow-400 hover:bg-yellow-50 transition-all duration-200"
                        data-rating="3">
                        <div class="flex items-center">
                            <span class="tossface text-[20px] sm:text-[24px] mr-3">😐</span>
                            <span class="text-[16px] sm:text-[18px] text-gray-700 pretendard-600">보통이다</span>
                        </div>
                    </button>

                    <button
                        class="rating-btn w-full p-3 text-left rounded-lg border-2 border-gray-200 hover:border-orange-400 hover:bg-orange-50 transition-all duration-200"
                        data-rating="2">
                        <div class="flex items-center">
                            <span class="tossface text-[20px] sm:text-[24px] mr-3">😕</span>
                            <span class="text-[16px] sm:text-[18px] text-gray-700 pretendard-600">별로였다</span>
                        </div>
                    </button>

                    <button
                        class="rating-btn w-full p-3 text-left rounded-lg border-2 border-gray-200 hover:border-red-400 hover:bg-red-50 transition-all duration-200"
                        data-rating="1">
                        <div class="flex items-center">
                            <span class="tossface text-[20px] sm:text-[24px] mr-3">😞</span>
                            <span class="text-[16px] sm:text-[18px] text-gray-700 pretendard-600">매우 별로였다</span>
                        </div>
                    </button>
                </div>

                <div class="flex space-x-3">
                    <button id="cancelRating"
                        class="flex-1 py-2 px-4 bg-gray-200 rounded-lg hover:bg-gray-300 transition-colors text-[14px] sm:text-[16px] text-gray-700 pretendard-600">
                        취소
                    </button>
                    <button id="submitRating"
                        class="flex-1 py-2 px-4 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed text-[14px] sm:text-[16px] pretendard-600"
                        disabled>
                        평가하기
                    </button>
                </div>
            </div>
        </div>


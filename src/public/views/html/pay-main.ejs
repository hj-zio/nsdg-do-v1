<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/resources/do_circle.svg">
    <title>DO :: 페이</title>

    <meta name="title" content="DO">
    <meta name="description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:title" content="DO">
    <meta property="og:description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:image" content="/resources/og_image.png">
    <meta property="og:url" content="v5.dghs.site">
    <meta name="format-detection" content="telephone=no">

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KCZ7CDL7SL"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag() { dataLayer.push(arguments); } gtag('js', new Date()); gtag('config', 'G-KCZ7CDL7SL'); 
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/pay-main.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body>
    <div class="
        relative flex flex-col items-center justify-start
        overflow-x-hidden overflow-y-hidden
        gap-5 text-[20px] text-gray-700 bg-gray-100 w-full full-height">

        <div id="TOP_AREA" class="
            relative flex justify-start items-end
            flex-row flex-nowrap 
            flex-grow-0 flex-shrink-0 basis-auto
            h-[80px] max-w-[600px] 
            overflow-x-hidden overflow-y-hidden
            px-[20px]
            w-full sm:w-[100%] md:w-[70%] lg:w-[50%]">
            <img src="/resources/do_logo.png" width="32" height="32" onclick="location.href='/'">
        </div>

        <div id="CONTENT_AREA" class="
            relative flex flex-col justify-start items-start
            flex-nowrap 
            flex-grow flex-shrink-0 basis-0
            h-[1fr] max-w-[600px]
            overflow-x-auto overflow-y-auto
            px-[20px] space-y-5
            w-full sm:w-[100%] md:w-[70%] lg:w-[50%]">
            <div id="pay-main" class="w-full space-y-5">
                <div class="flex flex-col space-y-5">
                    <div id="tabs" class="flex flex-row space-x-2 bg-white rounded-full">
                        <button data-tab="0" class="flex-1 p-2 text-[16px] sm:text-[18px] text-center pretendard-600 text-gray-400 transition-all duration-100 ease-in-out rounded-full">
                            결제
                        </button>
                        <button data-tab="1" class="flex-1 p-2 text-[16px] sm:text-[18px] text-center pretendard-600 text-gray-400 transition-all duration-100 ease-in-out rounded-full">
                            설정
                        </button>
                    </div>
                    <div id="tab-content">
                        <div data-content="0" class="flex flex-col justify-center items-center space-y-5 tab-content">
                            <div class="flex flex-col justify-between w-[100%] sm:w-[70%] h-[130px] px-5 py-4 rounded-xl bg-blue-600">
                                <div class="flex flex-row justify-between text-[16px] sm:text-[18px] text-white pretendard-600">
                                    <span class="">페이머니</span>
                                    <span class="cursor-pointer ms-2 px-3 py-1 text-[14px] sm:text-[16px] rounded-full text-blue-600 bg-blue-50 hover:bg-gray-300" onclick="location.href='/pay/charge'">충전하기</span>
                                </div>
                                <div class="flex flex-row items-center justify-end space-x-2">
                                    <span class="text-[16px] sm:text-[18px] text-white pretendard-600">잔액</span>
                                    <span id="pay_balance" class="text-[22px] sm:text-[24px] text-white pretendard-600">0원</span>
                                </div>
                            </div>
                            <div id="pay_history" class="flex flex-col w-[100%] sm:w-[70%] h-[300px] overflow-y-auto bg-white rounded-xl">
                                <span class="mt-5 text-center text-[16px] sm:text-[18px] text-gray-600 pretendard-400">결제내역이 없어요.</span>
                            </div>
                        </div>
                        <div data-content="1" class="flex flex-col space-y-5 tab-content">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>
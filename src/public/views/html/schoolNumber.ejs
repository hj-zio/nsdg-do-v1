    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/schoolNumber.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body>
    <div class="relative flex flex-col items-center justify-start gap-5 overflow-x-hidden overflow-y-hidden w-full full-height text-[20px] text-gray-700 bg-gray-100">
        <div id="TOP_AREA" class="relative flex flex-row flex-nowrap flex-grow-0 flex-shrink-0 basis-auto items-end justify-start w-full h-[80px] max-w-[600px] sm:w-[100%] md:w-[70%] lg:w-[50%] overflow-x-hidden overflow-y-hidden px-[20px]">
            <img src="/resources/do_logo.png" width="32" height="32" onclick="location.href='/'">
        </div>

        <div id="CONTENT_AREA" class="relative flex flex-col flex-nowrap flex-grow flex-shrink-0 basis-0 items-start justify-start w-full h-[1fr] max-w-[600px] sm:w-[100%] md:w-[70%] lg:w-[50%] overflow-x-auto overflow-y-auto px-[20px] space-y-5">
            <div class="w-full space-y-5">
                <div class="flex flex-col text-[24px] sm:text-[26px] text-gray-800 pretendard-600">
                    <span>학번을 어떻게 설정할까요?</span>
                    <span class="text-[14px] sm:text-[16px] text-gray-600 pretendard-500">
                        마지막 설정 후 30일이 지나야 다시 바꿀 수 있어요.
                    </span>
                </div>
                <div class="flex flex-row space-x-2">
                    <div class="flex flex-1 items-center space-x-2">
                        <select id="select-grade" class="w-full p-2 text-[16px] sm:text-[18px] text-gray-700 pretendard-500 border border-gray-300 bg-white rounded-md appearance-none outline-none">
                            <option value="1">1학년</option>
                            <option value="2">2학년</option>
                            <option value="3">3학년</option>
                        </select>
                    </div>
                    <div class="flex flex-1 items-center space-x-2">
                        <select id="select-class" class="w-full p-2 text-[16px] sm:text-[18px] text-gray-700 pretendard-500 border border-gray-300 bg-white rounded-md appearance-none outline-none">
                            <option value="1">1반</option>
                            <option value="2">2반</option>
                            <option value="3">3반</option>
                            <option value="4">4반</option>
                            <option value="5">5반</option>
                            <option value="6">6반</option>
                            <option value="7">7반</option>
                            <option value="8">8반</option>
                        </select>
                    </div>
                    <div class="flex flex-1 items-center space-x-2">
                        <select id="select-number" class="w-full p-2 text-[16px] sm:text-[18px] text-gray-700 pretendard-500 border border-gray-300 bg-white rounded-md appearance-none outline-none">
                            <option value="1">1번</option>
                            <option value="2">2번</option>
                            <option value="3">3번</option>
                            <option value="4">4번</option>
                            <option value="5">5번</option>
                            <option value="6">6번</option>
                            <option value="7">7번</option>
                            <option value="8">8번</option>
                            <option value="9">9번</option>
                            <option value="10">10번</option>
                            <option value="11">11번</option>
                            <option value="12">12번</option>
                            <option value="13">13번</option>
                            <option value="14">14번</option>
                            <option value="15">15번</option>
                            <option value="16">16번</option>
                            <option value="17">17번</option>
                            <option value="18">18번</option>
                            <option value="19">19번</option>
                            <option value="20">20번</option>
                            <option value="21">21번</option>
                            <option value="22">22번</option>
                            <option value="23">23번</option>
                            <option value="24">24번</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div id="BOTTOM_AREA" class="relative flex flex-col flex-nowrap flex-grow-0 flex-shrink-0 basis-auto items-start justify-end w-full sm:w-[100%] md:w-[70%] lg:w-[50%] h-[100px] max-w-[600px] overflow-x-hidden overflow-y-hidden px-[20px] pb-[50px] space-y-5">
            <button class="w-[100%] h-[48px] sm:h-[54px] text-[18px] sm:text-[20px] text-white text-center pretendard-500 rounded-[18px] bg-blue-600 hover:bg-blue-700 active:scale-95 transition-all duration-100 ease-in-out" onclick="setSchoolNum()">
                확인
            </button>
        </div>
    </div>


                <p class="text-[18px] sm:text-[20px] pretendard-500 text-gray-700">
                    모드를 선택해주세요.
                </p>
            </div>
            <div id="select_box" class="flex w-full flex-row items-center justify-center space-x-3 rounded-lg h-fit">
                <div class="flex flex-1 flex-col items-center justify-center h-[180px] cursor-pointer rounded-xl bg-gray-0 px-3 py-2 transition-all duration-100 ease-in-out hover:bg-gray-50 active:scale-95"
                    onclick="location.href='/store/manage'">
                    <span class="text-[36px] sm:text-[34px] tossface">📦</span>
                    <span class="text-[22px] sm:text-[24px] pretendard-600 text-gray-65">
                        매장 관리
                    </span>
                </div>
                <div class="flex flex-1 flex-col items-center justify-center h-[180px] cursor-pointer rounded-xl bg-gray-0 px-3 py-2 transition-all duration-100 ease-in-out hover:bg-gray-50 active:scale-95"
                    onclick="location.href='/store/kiosk'">
                    <span class="text-[36px] sm:text-[34px] tossface">💳</span>
                    <span class="text-[22px] sm:text-[24px] pretendard-600 text-gray-65">
                        키오스크
                    </span>
                </div>
            </div>
        </div>
    </div>
</body>


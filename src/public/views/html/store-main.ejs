    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/store.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body>
    <div class="
        relative flex flex-col items-center justify-start
        overflow-x-hidden overflow-y-hidden
        gap-5 text-[20px] text-gray-700 bg-gray-100 w-full full-height">

        <div id="TOP_AREA" class="
            relative flex justify-start items-end
            flex-row flex-nowrap 
            flex-grow-0 flex-shrink-0 basis-auto
            h-[80px] max-w-[600px] 
            overflow-x-hidden overflow-y-hidden
            px-[20px]
            w-full sm:w-[100%] md:w-[70%] lg:w-[50%]">
            <img src="/resources/do_logo.png" width="32" height="32" onclick="location.href='/'">
        </div>

        <div id="CONTENT_AREA" class="
            relative flex flex-col justify-start items-start
            flex-nowrap 
            flex-grow flex-shrink-0 basis-0
            h-[1fr] max-w-[600px]
            overflow-x-auto overflow-y-auto
            px-[20px] space-y-5
            w-full sm:w-[100%] md:w-[70%] lg:w-[50%]">
            <div id="intro_box" class="space-y-1">
                <p class="text-[22px] sm:text-[24px] pretendard-700 text-gray-800">
                    스토어에 오신 것을 환영합니다.

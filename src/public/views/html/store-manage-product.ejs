<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/resources/do_circle.svg">
    <title>DO :: 상품</title>

    <meta name="title" content="DO">
    <meta name="description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:title" content="DO">
    <meta property="og:description" content="논산대건고등학교 인트라넷 DO 입니다.">
    <meta property="og:image" content="/resources/og_image.png">
    <meta property="og:url" content="v5.dghs.site">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.1/css/dataTables.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.1/js/dataTables.min.js"></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KCZ7CDL7SL"></script>
    <script> window.dataLayer = window.dataLayer || []; function gtag() { dataLayer.push(arguments); } gtag('js', new Date()); gtag('config', 'G-KCZ7CDL7SL'); 
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/views/js/store-manage-product.js"></script>
    <script>
        function setVh() {
            let vh = window.innerHeight * 0.01;
            document.documentElement.style.setProperty('--vh', `${vh}px`);
        }

        window.addEventListener('resize', setVh);
        document.addEventListener('DOMContentLoaded', setVh);
        setVh();
    </script>
    <link rel="stylesheet" href="/views/css/defalut.css">
</head>

<body class="h-screen">
    <div class="flex h-full text-[18px] sm:text-[20px] text-gray-600 pretendard-500">
        <div class="hidden md:block w-[230px] flex flex-col space-y-4 bg-gray-100 px-4 py-5 text-gray-600">
            <span class="text-[18px] sm:text-[20px] text-gray-700 pretendard-700">매장 관리</span>
            <div class="flex flex-col space-y-2">
                <span class="cursor-pointer rounded-lg py-1 text-[16px] sm:text-[18px] text-gray-600 pretendard-600 active:scale-95 transition-all duration-100 ease-in-out">
                    매출
                </span>
                <span class="cursor-pointer rounded-lg py-1 text-[16px] sm:text-[18px] text-gray-600 pretendard-600 active:scale-95 transition-all duration-100 ease-in-out">
                    정산
                </span>
                <span class="cursor-pointer rounded-lg py-1 text-[16px] sm:text-[18px] text-blue-500 pretendard-600 active:scale-95 transition-all duration-100 ease-in-out">
                    상품
                </span>
                <span class="cursor-pointer rounded-lg py-1 text-[16px] sm:text-[18px] text-gray-600 pretendard-600 active:scale-95 transition-all duration-100 ease-in-out">
                    결제내역
                </span>
            </div>
        </div>
        <div class="flex-1 p-4">
            <div class="md:hidden flex justify-between items-center mb-4">
                <span class="text-[20px] text-gray-600 pretendard-600">상품 관리</span>
                <button onclick="toggleMobileMenu()" class="text-gray-700 p-2 focus:outline-none">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
                </button>
            </div>
            <div id="mobile-menu" class="md:hidden hidden mb-4 bg-gray-50 p-4 rounded-lg">
                <ul>
                    <li class="mb-2"><a href="/store/manage-sales" class="block cursor-pointer text-gray-600">매출</a></li>
                    <li class="mb-2"><a href="/store/manage-settlement" class="block cursor-pointer text-gray-600">정산</a></li>
                    <li class="mb-2"><a href="/store/manage-product" class="block cursor-pointer text-gray-600">상품</a></li>
                    <li class="mb-2"><a href="/store/manage-record" class="block cursor-pointer text-gray-600">결제내역</a></li>
                </ul>
            </div>
            <div id="main" class="flex flex-col w-full space-y-3">
                <div class="flex flex-wrap md:flex-nowrap w-full gap-y-2 md:gap-y-0 gap-x-2">
                    <div class="flex flex-row w-full md:flex-1 items-center justify-start px-3 py-2 space-x-2 bg-white rounded-lg outline outline-1 outline-gray-300">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="size-[14px] sm:size-[16px]">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                        </svg>
                        <input id="product_input" class="outline-none text-[14px] sm:text-[16px] pretendard-400 text-gray-600" placeholder="제품명이나 바코드를 입력해주세요." oninput="queryProductInfo()">
                    </div>
                    <div id="button_group" class="flex flex-row w-full md:w-auto md:ms-2 space-x-2">
                        <span class="w-1/3 md:w-auto m-0 text-center px-3 py-2 cursor-pointer transition-all duration-100 ease-in-out hover:bg-blue-200 active:scale-95 bg-blue-100 rounded-lg text-[14px] sm:text-[16px] pretendard-400 text-blue-600" onclick="createProductModal()">추가</span>
                        <span class="w-1/3 md:w-auto m-0 text-center px-3 py-2 cursor-pointer transition-all duration-100 ease-in-out hover:bg-amber-200 active:scale-95 bg-amber-100 rounded-lg text-[14px] sm:text-[16px] pretendard-400 text-amber-600" onclick="changeProductModal()">변경</span>
                        <span class="w-1/3 md:w-auto m-0 text-center px-3 py-2 cursor-pointer transition-all duration-100 ease-in-out hover:bg-red-200 active:scale-95 bg-red-100 rounded-lg text-[14px] sm:text-[16px] pretendard-400 text-red-600" onclick="deleteProductModal()">삭제</span>
                    </div>
                </div>
                <div id="product_table" class="overflow-x-auto"></div>
                <div id="status" class="text-[14px] sm:text-[16px] text-gray-600 pretendard-500"></div>
            </div>
        </div>
    </div>

    <div id="modal" class="fixed inset-0 z-40 bg-black/50 flex items-center justify-center hidden">
        <div class="bg-white rounded-lg p-6 w-11/12 max-w-md transition-all ease-in-out duration-100">
            <div id="modal_title" class="text-[18px] sm:text-[20px] pretendard-600 text-gray-600 mb-4 block">
            </div>
            <div id="modal_content" class="text-[14px] sm:text-[16px] pretendard-500 text-gray-600 block">
            </div>
        </div>
    </div>
</body>

</html>